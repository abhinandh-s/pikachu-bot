{
  "tasks": {
    "start": "deno run --allow-net --allow-env --allow-read main.ts"
  },
  "imports": {
     "@std/path": "https://deno.land/std@0.224.0/path/mod.ts",
    "grammy": "https://deno.land/x/grammy@v1.44.0/mod.ts",
      "grammy/types.ts": "https://deno.land/x/grammy@v1.34.0/types.ts",
  },
  "fmt": {
    "lineWidth": 150,
    "singleQuote": false,
    "trailingCommas": "never",
    "proseWrap": "never",
    "exclude": ["src/db/", "src/generated/**/*.ts"]
  },
}
